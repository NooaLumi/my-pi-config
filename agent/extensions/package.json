{
   "name": "pi-extensions",
   "version": "0.1.0",
   "license": "MIT",
   "type": "module",
   "scripts": {
      "check": "biome check --write --error-on-warnings . && tsgo --noEmit"
   },
   "keywords": [
      "pi-package",
      "mistral"
   ],
   "author": "Nooa Lumilaakso",
   "workspaces": [
      "debug",
      "guard",
      "identity",
      "startup-header",
      "stt",
      "todo",
      "web-scrape",
      "web-search",
      "_unused-mistral-websearch",
      "_unused-ollama-summarizer"
   ],
   "pi": {
      "extensions": [
         "./guard/guard.ts",
         "./identity/identity.ts",
         "./startup-header/startup-header.ts",
         "./stt/stt.ts",
         "./todo/todo.ts",
         "./web-scrape/web-scrape.ts",
         "./web-search/web-search.ts"
      ]
   },
   "peerDependencies": {
      "@earendil-works/pi-coding-agent": "*"
   },
   "dependencies": {
      "@mistralai/mistralai": "^2.2.1",
      "@sinclair/typebox": "^0.34.49"
   },
   "devDependencies": {
      "@biomejs/biome": "2.3.5",
      "@types/node": "^25.6.0",
      "@typescript/native-preview": "^7.0.0-dev.20260425.1",
      "tsx": "^4.21.0",
      "typescript": "^6.0.3"
   }
}
